        "seg3 = df.iloc[601:].copy()\n",
        "\n",
        "x_cols = ['stake_yield', 'ret_eth_btc', 'rv_eth_btc']\n",
        "\n",
        "\n",
        "def fit_seg(name: str, sub: pd.DataFrame):\n",
        "    use = sub[['spread', *x_cols]].dropna()\n",
        "    res = ols_hac(use['spread'], use[x_cols], maxlags=5)\n",
        "    return {\n",
        "        'segment': name,\n",
        "        'start_date': sub['date'].iloc[0],\n",
        "        'end_date': sub['date'].iloc[-1],\n",
        "        'nobs': int(res.nobs),\n",
        "        'stake_coef': float(res.params['stake_yield']),\n",
        "        'stake_pvalue': float(res.pvalues['stake_yield']),\n",
        "        'ret_coef': float(res.params.get('ret_eth_btc', np.nan)),\n",
        "        'ret_pvalue': float(res.pvalues.get('ret_eth_btc', np.nan)),\n",
        "        'rv_coef': float(res.params.get('rv_eth_btc', np.nan)),\n",
        "        'rv_pvalue': float(res.pvalues.get('rv_eth_btc', np.nan)),\n",
        "        'r2': float(res.rsquared),\n",
        "    }\n",
        "\n",
        "\n",
        "seg_summary = pd.DataFrame([\n",
        "    fit_seg('seg1_0_300', seg1),\n",
        "    fit_seg('seg2_301_600', seg2),\n",
        "    fit_seg('seg3_601_end', seg3),\n",
        "])\n",
        "print('=== Non-overlapping 3-segment HAC results ===')\n",
        "print(seg_summary.to_string(index=False))\n",
        "\n",
        "\n",
        "# interaction model: slope(stake_yield)가 regime에 따라 달라지는지 직접 검정\n",
        "work = df.copy().reset_index(drop=True)\n",
        "work['regime2'] = ((work.index >= 301) & (work.index <= 600)).astype(int)\n",
        "work['regime3'] = (work.index >= 601).astype(int)\n",
        "work['sy_x_regime2'] = work['stake_yield'] * work['regime2']\n",
        "work['sy_x_regime3'] = work['stake_yield'] * work['regime3']\n",
        "\n",
        "int_cols = x_cols + ['regime2', 'regime3', 'sy_x_regime2', 'sy_x_regime3']\n",
        "int_use = work[['spread', *int_cols]].dropna()\n",
        "res_int = ols_hac(int_use['spread'], int_use[int_cols], maxlags=5)\n",
        "\n",
        "print('\\n=== Interaction model (HAC) ===')\n",
        "print(res_int.summary())\n",
        "\n",
        "# H0: slope break 없음 (interaction 계수 둘 다 0)\n",
        "wald = res_int.wald_test('sy_x_regime2 = 0, sy_x_regime3 = 0')\n",
        "print('\\n=== Wald test for stake_yield slope breaks ===')\n",
        "print({'stat': float(np.asarray(wald.statistic).squeeze()), 'pvalue': float(np.asarray(wald.pvalue).squeeze())})\n",
        "\n",
        "\n",
        "# Chow-type break test (고전 OLS 기준; 참고용)\n",
        "def chow_break_test(data: pd.DataFrame, split_at: int, y: str, xs: list[str]) -> dict:\n",
        "    pool = data[[y, *xs]].dropna().reset_index(drop=True)\n",
        "    left = pool.iloc[:split_at]\n",
        "    right = pool.iloc[split_at:]\n",
        "    k = len(xs) + 1  # const 포함\n",
        "    n1, n2 = len(left), len(right)\n",
        "    if n1 <= k or n2 <= k:\n",
        "        return {'split_at': split_at, 'n_left': n1, 'n_right': n2, 'F': np.nan, 'pvalue': np.nan}\n",
        "\n",
        "    Xp = sm.add_constant(pool[xs], has_constant='add')\n",
        "    X1 = sm.add_constant(left[xs], has_constant='add')\n",
        "    X2 = sm.add_constant(right[xs], has_constant='add')\n",
        "    yp, y1, y2 = pool[y], left[y], right[y]\n",
        "\n",
        "    rp = sm.OLS(yp, Xp).fit()\n",
        "    r1 = sm.OLS(y1, X1).fit()\n",
        "    r2 = sm.OLS(y2, X2).fit()\n",
        "\n",
        "    rss_p = float(np.sum(rp.resid ** 2))\n",
        "    rss_1 = float(np.sum(r1.resid ** 2))\n",
        "    rss_2 = float(np.sum(r2.resid ** 2))\n",
        "\n",
        "    num = (rss_p - (rss_1 + rss_2)) / k\n",
        "    den = (rss_1 + rss_2) / (n1 + n2 - 2 * k)\n",
        "    F = num / den if den > 0 else np.nan\n",
        "    pval = 1 - stats.f.cdf(F, k, n1 + n2 - 2 * k) if pd.notna(F) else np.nan\n",
        "\n",
        "    return {'split_at': split_at, 'n_left': n1, 'n_right': n2, 'F': F, 'pvalue': pval}\n",
        "\n",
        "\n",
        "chow_df = pd.DataFrame([\n",
        "    chow_break_test(df, 301, 'spread', x_cols),\n",
        "    chow_break_test(df, 601, 'spread', x_cols),\n",
        "])\n",
        "print('\\n=== Chow-type break tests (OLS reference) ===')\n",
        "print(chow_df.to_string(index=False))"
      ]
    },
