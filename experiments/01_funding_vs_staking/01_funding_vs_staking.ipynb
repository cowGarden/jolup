      "source": [
        "# [INFO] 이벤트 날짜 기반 구조변화 검정 + MA(롤링 계수) 반전 시점 탐색\n",
        "import statsmodels.api as sm\n",
        "\n",
        "work = df.copy()\n",
        "work['date'] = pd.to_datetime(work['date'])\n",
        "x_cols = ['stake_yield', 'ret_eth_btc', 'rv_eth_btc']\n",
        "\n",
        "break_candidates = [\n",
        "    ('US spot ETH ETF start', '2024-07-24'),\n",
        "    ('ETH ETF inflow / rally starts', '2025-07-10'),\n",
        "    ('Reuters 6M high', '2025-07-18'),\n",
        "    ('ETH rally follow-through', '2025-07-21'),\n",
        "    ('Treasury narrative broadening', '2025-07-29'),\n",
        "]\n",
        "\n",
        "\n",
        "def _ols_chow_like(pool: pd.DataFrame, split_date: pd.Timestamp, y_col: str, x_list: list[str]) -> tuple[float, float, int, int]:\n",
        "    reg = pool[[y_col, 'date', *x_list]].dropna().sort_values('date').reset_index(drop=True)\n",
        "    left = reg[reg['date'] < split_date]\n",
        "    right = reg[reg['date'] >= split_date]\n",
        "    k = len(x_list) + 1\n",
        "    n1, n2 = len(left), len(right)\n",
        "    if n1 <= k or n2 <= k:\n",
        "        return np.nan, np.nan, n1, n2\n",
        "\n",
        "    Xp = sm.add_constant(reg[x_list], has_constant='add')\n",
        "    X1 = sm.add_constant(left[x_list], has_constant='add')\n",
        "    X2 = sm.add_constant(right[x_list], has_constant='add')\n",
        "    yp, y1, y2 = reg[y_col], left[y_col], right[y_col]\n",
        "\n",
        "    rp = sm.OLS(yp, Xp).fit()\n",
        "    r1 = sm.OLS(y1, X1).fit()\n",
        "    r2 = sm.OLS(y2, X2).fit()\n",
        "\n",
        "    rss_p = float(np.sum(rp.resid ** 2))\n",
        "    rss_1 = float(np.sum(r1.resid ** 2))\n",
        "    rss_2 = float(np.sum(r2.resid ** 2))\n",
        "    num = (rss_p - (rss_1 + rss_2)) / k\n",
        "    den = (rss_1 + rss_2) / (n1 + n2 - 2 * k)\n",
        "    F = num / den if den > 0 else np.nan\n",
        "    pval = 1 - stats.f.cdf(F, k, n1 + n2 - 2 * k) if pd.notna(F) else np.nan\n",
        "    return F, pval, n1, n2\n",
        "\n",
        "\n",
        "rows = []\n",
        "for label, date_str in break_candidates:\n",
        "    bdate = pd.Timestamp(date_str)\n",
        "    reg = work[['date', 'spread', *x_cols]].dropna().sort_values('date').reset_index(drop=True)\n",
        "\n",
        "    pre = reg[reg['date'] < bdate]\n",
        "    post = reg[reg['date'] >= bdate]\n",
        "\n",
        "    if len(pre) < 40 or len(post) < 40:\n",
        "        rows.append({\n",
        "            'break_label': label,\n",
        "            'break_date': bdate.date(),\n",
        "            'n_pre': len(pre),\n",
        "            'n_post': len(post),\n",
        "            'pre_stake_coef': np.nan,\n",
        "            'pre_stake_p': np.nan,\n",
        "            'post_stake_coef': np.nan,\n",
        "            'post_stake_p': np.nan,\n",
        "            'interaction_sy_x_post_coef': np.nan,\n",
        "            'interaction_sy_x_post_p': np.nan,\n",
        "            'chow_F_ols_ref': np.nan,\n",
        "            'chow_p_ols_ref': np.nan,\n",
        "            'note': 'too few observations in one side',\n",
        "        })\n",
        "        continue\n",
        "\n",
        "    res_pre = ols_hac(pre['spread'], pre[x_cols], maxlags=5)\n",
        "    res_post = ols_hac(post['spread'], post[x_cols], maxlags=5)\n",
        "\n",
        "    int_df = reg.copy()\n",
        "    int_df['post'] = (int_df['date'] >= bdate).astype(int)\n",
        "    int_df['sy_x_post'] = int_df['stake_yield'] * int_df['post']\n",
        "    int_cols = x_cols + ['post', 'sy_x_post']\n",
        "    res_int = ols_hac(int_df['spread'], int_df[int_cols], maxlags=5)\n",
        "\n",
        "    chow_F, chow_p, n1, n2 = _ols_chow_like(reg, bdate, 'spread', x_cols)\n",
        "\n",
        "    rows.append({\n",
        "        'break_label': label,\n",
        "        'break_date': bdate.date(),\n",
        "        'n_pre': n1,\n",
        "        'n_post': n2,\n",
        "        'pre_stake_coef': float(res_pre.params['stake_yield']),\n",
        "        'pre_stake_p': float(res_pre.pvalues['stake_yield']),\n",
        "        'post_stake_coef': float(res_post.params['stake_yield']),\n",
        "        'post_stake_p': float(res_post.pvalues['stake_yield']),\n",
        "        'interaction_sy_x_post_coef': float(res_int.params['sy_x_post']),\n",
        "        'interaction_sy_x_post_p': float(res_int.pvalues['sy_x_post']),\n",
        "        'chow_F_ols_ref': chow_F,\n",
        "        'chow_p_ols_ref': chow_p,\n",
        "        'note': '',\n",
        "    })\n",
        "\n",
        "break_summary = pd.DataFrame(rows).sort_values('break_date')\n",
        "print('=== Event-date structural break summary ===')\n",
        "print(break_summary.to_string(index=False))\n",
        "\n",
        "\n",
        "# [INFO] MA/롤링 계수로 반전 시점 탐색\n",
        "reg_all = work[['date', 'spread', *x_cols]].dropna().sort_values('date').reset_index(drop=True)\n",
        "window = 180\n",
        "coef_rows = []\n",
        "\n",
        "for end in range(window - 1, len(reg_all)):\n",
        "    sub = reg_all.iloc[end - window + 1:end + 1]\n",
        "    res = ols_hac(sub['spread'], sub[x_cols], maxlags=5)\n",
        "    coef_rows.append({\n",
        "        'end_date': sub['date'].iloc[-1],\n",
        "        'stake_coef': float(res.params.get('stake_yield', np.nan)),\n",
        "        'stake_p': float(res.pvalues.get('stake_yield', np.nan)),\n",
        "    })\n",
        "\n",
        "roll = pd.DataFrame(coef_rows)\n",
        "roll['stake_coef_ma30'] = roll['stake_coef'].rolling(30, min_periods=20).mean()\n",
        "\n",
        "# 반전 정의: MA30 계수가 20개 윈도우 연속 양수인 최초 시점\n",
        "sustain_n = 20\n",
        "roll['ma_pos'] = (roll['stake_coef_ma30'] > 0).astype(int)\n",
        "roll['ma_pos_run'] = roll['ma_pos'].groupby((roll['ma_pos'] != roll['ma_pos'].shift()).cumsum()).cumsum()\n",
        "flip_candidates = roll[(roll['ma_pos'] == 1) & (roll['ma_pos_run'] >= sustain_n)]\n",
        "flip_date = flip_candidates['end_date'].iloc[0] if not flip_candidates.empty else pd.NaT\n",
        "\n",
        "print('\\n=== Rolling(180d) stake_yield coefficient reversal check ===')\n",
        "print({\n",
        "    'first_sustained_positive_date': None if pd.isna(flip_date) else pd.Timestamp(flip_date).date().isoformat(),\n",
        "    'sustain_windows': sustain_n,\n",
        "    'last_coef': float(roll['stake_coef'].iloc[-1]) if not roll.empty else np.nan,\n",
        "    'last_coef_ma30': float(roll['stake_coef_ma30'].iloc[-1]) if not roll.empty else np.nan,\n",
        "})\n",
        "\n",
        "fig, axes = plt.subplots(2, 1, figsize=(11, 8), sharex=True)\n",
        "axes[0].plot(roll['end_date'], roll['stake_coef'], label='rolling stake coef (180d)', alpha=0.6)\n",
        "axes[0].plot(roll['end_date'], roll['stake_coef_ma30'], label='MA30 of rolling coef', linewidth=2)\n",
        "axes[0].axhline(0, color='black', linewidth=0.8)\n",
        "if not pd.isna(flip_date):\n",
        "    axes[0].axvline(pd.Timestamp(flip_date), color='red', linestyle='--', alpha=0.7, label='first sustained positive')\n",
        "axes[0].set_ylabel('coef')\n",
        "axes[0].legend()\n",
        "axes[0].set_title('Rolling stake_yield coefficient and MA30')\n",
        "\n",
        "axes[1].plot(roll['end_date'], roll['stake_p'], label='rolling p-value (stake_yield)', color='tab:orange')\n",
        "axes[1].axhline(0.10, color='gray', linestyle='--', linewidth=1, label='0.10')\n",
        "axes[1].axhline(0.05, color='black', linestyle='--', linewidth=1, label='0.05')\n",
        "axes[1].set_ylabel('p-value')\n",
        "axes[1].set_xlabel('window end date')\n",
        "axes[1].legend()\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    },
